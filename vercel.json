{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/mobile/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/mobile/dist/index.html"
    }
  ]
}
